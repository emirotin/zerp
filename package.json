{
  "name": "@emirotin/zerp",
  "version": "0.6.1",
  "description": "Zero-config presentation framework for slide decks authored in HTML and/or Markdown.",
  "keywords": [
    "cli",
    "html",
    "markdown",
    "presentation",
    "slides",
    "typescript"
  ],
  "homepage": "https://github.com/emirotin/zerp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/emirotin/zerp.git"
  },
  "bin": {
    "zerp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "examples/casino/slides",
    "README.md",
    "LICENSE",
    "llms.txt",
    "MIGRATION.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "demo": "node ./scripts/demo.mjs",
    "shot": "node ./scripts/shot.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "test": "pnpm build && node --test test/*.test.mjs",
    "test:browser": "ZERP_RUN_BROWSER_TEST=1 node --test test/verify.test.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings --node-plugin --import-plugin src scripts test .zed",
    "lint:fix": "oxlint --fix --deny-warnings --node-plugin --import-plugin src scripts test .zed"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.9",
    "apca-w3": "^0.1.9",
    "css-tree": "^3.2.1",
    "htmlparser2": "^10.1.0",
    "linkedom": "^0.18.12",
    "marked": "^18.0.5",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@evilmartians/harmony": "^1.4.0",
    "@types/node": "^24.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "oxfmt --write",
      "oxlint --fix --deny-warnings --node-plugin --import-plugin"
    ]
  },
  "engines": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0"
}
